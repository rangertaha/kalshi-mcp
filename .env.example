# kalshi-mcp environment configuration.
# Copy to .env and fill in your values:  cp .env.example .env
# (.env is gitignored; never commit real keys.)

# --- Optional: authentication ---
# Public market-data tools work WITHOUT credentials. Set both to enable
# authenticated portfolio/order tools. The private key is the PEM you downloaded
# when creating the API key (paste the full PEM, including the BEGIN/END lines).
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY=

# --- Optional: server behavior ---
# API base URL (default: https://api.elections.kalshi.com/trade-api/v2).
# KALSHI_BASE_URL=

# Comma-separated toolset names to enable, or "all" (default).
KALSHI_TOOLSETS=all

# "true" exposes only read-only tools.
KALSHI_READONLY=false
